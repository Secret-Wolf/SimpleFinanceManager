# Finanzmanager - Environment Variables
# Kopiere diese Datei zu .env und passe die Werte an

# JWT Secret Key - MUSS geändert werden!
# Generieren mit: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# Debug-Modus (true/false) - in Production IMMER false!
DEBUG=false

# Erlaubte Origins für CORS (komma-separiert)
# Leer lassen für same-origin (Standard für LAN-Betrieb)
# Beispiel: https://finance.meinedomain.de
ALLOWED_ORIGINS=

# Traefik/HTTPS (nur für docker-compose.yml mit Traefik)
ACME_EMAIL=deine@email.de

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_MINUTE=5

# Upload Limit in MB
MAX_UPLOAD_SIZE_MB=10

# Token Gültigkeit
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
